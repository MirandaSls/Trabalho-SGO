@startuml diagrama-de-componentes
title Diagrama de Componentes - Sistema de Gestao das Olimpiadas (SGO)

skinparam componentStyle rectangle
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 60

' ============== CLIENTE ==============
package "Cliente" {
  [Interface de Usuario\n(Web / Mobile)] as UI
}

' ============== API GATEWAY ==============
package "Apresentacao" {
  [API Gateway] as GW
}

' ============== BACKEND ==============
package "Backend SGO" {
  [Modulo de\nAutenticacao]      as AUTH
  [Modulo de\nCompeticoes]       as MCO
  [Modulo de\nInscricoes]        as MIN
  [Modulo de\nAlocacao de Locais] as MAL
  [Modulo de\nResultados]        as MRE
  [Modulo de\nAtletas]           as MAT
  [Modulo de\nRelatorios]        as MRL
}

' ============== INFRAESTRUTURA ==============
package "Persistencia" {
  database "Banco de Dados\nRelacional" as DB
  [Servidor de\nArquivos]               as FS
}

' ============== INTERFACES PROVIDAS / REQUERIDAS ==============
' Cliente -> Gateway (interface lollipop)
interface "HTTPS / REST" as IREST
UI --( IREST
IREST -- GW

' Gateway expoe APIs para os modulos
GW --> AUTH : IAutenticacao
GW --> MCO  : ICompeticoes
GW --> MIN  : IInscricoes
GW --> MAL  : IAlocacao
GW --> MRE  : IResultados
GW --> MAT  : IAtletas
GW --> MRL  : IRelatorios

' Dependencias-chave entre modulos (apenas as essenciais)
MIN ..> MCO : <<use>>
MIN ..> MAT : <<use>>
MAL ..> MCO : <<use>>
MRE ..> MCO : <<use>>
MRL ..> MRE : <<use>>

' Acesso ao banco (interface JDBC unica)
AUTH -down-( DB : JDBC
MCO  -down-( DB : JDBC
MIN  -down-( DB : JDBC
MAL  -down-( DB : JDBC
MRE  -down-( DB : JDBC
MAT  -down-( DB : JDBC
MRL  -down-( DB : JDBC

' Acesso ao file server (so o modulo de relatorios)
MRL -down-( FS : FileSystem

@enduml
