@startuml diagrama-de-pacotes
title Diagrama de Pacotes - Sistema de Gestao das Olimpiadas (SGO)

skinparam packageStyle rectangle
skinparam linetype polyline
skinparam nodesep 40
skinparam ranksep 60

package "br.com.sgo" {

  package "apresentacao" {
    package "view"
    package "controller"
  }

  package "aplicacao" {
    package "servicos"
    package "dto"
  }

  package "relatorios" {
    package "geradores"
    package "templates"
  }

  package "dominio" {
    package "entidades"
    package "enums"
    package "repositorios"
  }

  package "persistencia" {
    package "jpa"
    package "mappers"
  }

  package "infraestrutura" {
    package "seguranca"
    package "config"
    package "utils"
  }
}

' --- Dependencias entre camadas ---
apresentacao   ..>  aplicacao      : <<usa>>
aplicacao      ..>  dominio        : <<usa>>
aplicacao      ..>  relatorios     : <<usa>>
relatorios     ..>  dominio        : <<usa>>
persistencia   ..>  dominio        : <<implementa>>
persistencia   ..>  infraestrutura : <<usa>>
apresentacao   ..>  infraestrutura : <<usa>>
aplicacao      ..>  infraestrutura : <<usa>>

note right of apresentacao
  Interface com o usuario
  (Web / REST)
end note

note right of dominio
  Nucleo do sistema
  Regras de negocio
end note

note right of persistencia
  Acesso a dados
  JPA / Hibernate
end note

note bottom of infraestrutura
  Recursos transversais
  (seguranca, config, utils)
end note

@enduml
